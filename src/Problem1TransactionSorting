class Client {

    String name;
    int riskScore;
    double accountBalance;

    public Client(String name, int riskScore, double accountBalance) {
        this.name = name;
        this.riskScore = riskScore;
        this.accountBalance = accountBalance;
    }

    @Override
    public String toString() {
        return name +
                " : Risk Score = " + riskScore +
                " , Balance = " + accountBalance;
    }
}

public class Problem2ClientRiskRanking {

    public static void bubbleSort(Client[] clients) {

        int swaps = 0;

        for (int i = 0; i < clients.length - 1; i++) {

            boolean swapped = false;

            for (int j = 0; j < clients.length - i - 1; j++) {

                if (clients[j].riskScore >
                        clients[j + 1].riskScore) {

                    Client temp = clients[j];

                    clients[j] = clients[j + 1];

                    clients[j + 1] = temp;

                    swaps++;
                    swapped = true;
                }
            }

            if (!swapped) {
                break;
            }
        }

        System.out.println("Bubble Sort (Ascending Risk Score):");

        for (Client c : clients) {
            System.out.println(c);
        }

        System.out.println("Total Swaps : " + swaps);
    }

    public static void insertionSort(Client[] clients) {

        for (int i = 1; i < clients.length; i++) {

            Client key = clients[i];

            int j = i - 1;

            while (j >= 0 &&
                    clients[j].riskScore < key.riskScore) {

                clients[j + 1] = clients[j];

                j--;
            }

            clients[j + 1] = key;
        }

        System.out.println("\nInsertion Sort (Descending Risk Score):");

        for (Client c : clients) {
            System.out.println(c);
        }
    }

    public static void topRiskClients(Client[] clients) {

        System.out.println("\nTop High Risk Clients:");

        int limit = Math.min(10, clients.length);

        for (int i = 0; i < limit; i++) {

            System.out.println(
                    clients[i].name +
                            " (" +
                            clients[i].riskScore +
                            ")");
        }
    }

    public static void main(String[] args) {

        Client[] clients = {

                new Client("ClientA", 20, 15000),

                new Client("ClientB", 50, 20000),

                new Client("ClientC", 80, 5000),

                new Client("ClientD", 65, 12000),

                new Client("ClientE", 35, 25000)
        };

        Client[] bubbleArray = clients.clone();

        Client[] insertionArray = clients.clone();

        bubbleSort(bubbleArray);

        insertionSort(insertionArray);

        topRiskClients(insertionArray);
    }
}
