class RiskRecord {

    int riskId;
    String clientName;
    double riskValue;

    public RiskRecord(
            int riskId,
            String clientName,
            double riskValue) {

        this.riskId = riskId;
        this.clientName = clientName;
        this.riskValue = riskValue;
    }

    @Override
    public String toString() {

        return "Risk ID : " +
                riskId +
                " , Client : " +
                clientName +
                " , Risk Value : " +
                riskValue;
    }
}

public class Problem6RiskThresholdLookup {

    public static int linearSearch(
            RiskRecord[] records,
            double threshold) {

        for (int i = 0; i < records.length; i++) {

            if (records[i].riskValue >= threshold) {
                return i;
            }
        }

        return -1;
    }

    public static int binarySearch(
            RiskRecord[] records,
            double threshold) {

        int left = 0;
        int right = records.length - 1;

        int result = -1;

        while (left <= right) {

            int mid = (left + right) / 2;

            if (records[mid].riskValue >= threshold) {

                result = mid;
                right = mid - 1;

            } else {

                left = mid + 1;
            }
        }

        return result;
    }

    public static void sortRecords(
            RiskRecord[] records) {

        for (int i = 0; i < records.length - 1; i++) {

            for (int j = 0;
                 j < records.length - i - 1;
                 j++) {

                if (records[j].riskValue >
                        records[j + 1].riskValue) {

                    RiskRecord temp = records[j];

                    records[j] = records[j + 1];

                    records[j + 1] = temp;
                }
            }
        }
    }

    public static void displayResult(
            RiskRecord[] records,
            int index) {

        if (index != -1) {

            System.out.println(
                    "Matching Record:");

            System.out.println(records[index]);

        } else {

            System.out.println(
                    "No Matching Record Found");
        }

        System.out.println();
    }

    public static void main(String[] args) {

        RiskRecord[] records = {

                new RiskRecord(
                        1,
                        "ClientA",
                        25.5),

                new RiskRecord(
                        2,
                        "ClientB",
                        70.0),

                new RiskRecord(
                        3,
                        "ClientC",
                        45.8),

                new RiskRecord(
                        4,
                        "ClientD",
                        90.2)
        };

        double threshold = 50.0;

        System.out.println(
                "Linear Search Result:");

        int linearIndex =
                linearSearch(
                        records,
                        threshold);

        displayResult(
                records,
                linearIndex);

        sortRecords(records);

        System.out.println(
                "Binary Search Result:");

        int binaryIndex =
                binarySearch(
                        records,
                        threshold);

        displayResult(
                records,
                binaryIndex);
    }
}